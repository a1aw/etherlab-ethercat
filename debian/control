Package: etherlab-ethercat
Architecture: any
Multi-Arch: same
Depends: ${shlibs:Depends}, ${misc:Depends}
Recommends: etherlab-ethercat-dkms
Description: IgH EtherCAT userspace runtime library
 Shared library for applications using the IgH EtherCAT master
 userspace API. Also includes libfakeethercat for dry-run and simulation
 without a configured master or attached slaves.

Package: etherlab-ethercat-dev
Architecture: any
Multi-Arch: same
Depends: etherlab-ethercat (= ${binary:Version}),
         ${misc:Depends}
Description: Headers and development files for IgH EtherCAT userspace library
 Headers, static library, pkg-config, and CMake files for building
 applications against libethercat.

Package: etherlab-ethercat-dkms
Architecture: all
Depends: ${misc:Depends}, dkms
Recommends: linux-headers-amd64 | linux-headers-arm64 | linux-headers-generic | linux-headers
Description: IgH EtherCAT kernel modules (DKMS)
 Kernel module sources for the IgH EtherCAT master, built automatically
 on the target system via DKMS.

Package: etherlab-ethercat-utils
Architecture: any
Depends: etherlab-ethercat (= ${binary:Version}),
         ${shlibs:Depends},
         ${misc:Depends}
Description: Tools and configuration for IgH EtherCAT master
 Command-line tools, configuration files, systemd unit, and udev rules
 for the IgH EtherCAT master.
